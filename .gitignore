/*.deploy.json

# Compiled packages (build artifacts — regenerated from examples/)
packages/
# Coverage
.coverage
coverage.json
htmlcov/

# VM files
*.vm

# Termin packages (root level — build artifacts)
*.termin.pkg

# Claude Code: settings.json is the team baseline (committed).
# settings.local.json is the per-developer override slot (gitignored).
.claude/settings.local.json
