  "computes": [
    {
      "name": {
        "display": "calculate order total",
        "snake": "calculate_order_total",
        "pascal": "CalculateOrderTotal"
      },
      "shape": "TRANSFORM",
      "input_content": [
        "orders"
      ],
      "output_content": [
        "orders"
      ],
      "body_lines": [
        "order.total = order.lines.reduce((acc, line) => acc + line.quantity * line.unit_price, 0)"
      ],
      "required_scope": "write orders",
      "required_role": null,
      "input_params": [],
      "output_params": []
    },
    {
      "name": {
        "display": "revenue report",
        "snake": "revenue_report",
        "pascal": "RevenueReport"
      },
      "shape": "REDUCE",
      "input_content": [
        "orders"
      ],
      "output_content": [
        "reports"
      ],
      "body_lines": [
        "report.total_count = orders.length; report.total_revenue = orders.reduce((acc, o) => acc + o.total, 0)"
      ],
      "required_scope": "read orders",
      "required_role": null,
      "input_params": [],
      "output_params": []
    },
    {
      "name": {
        "display": "split order into lines",
        "snake": "split_order_into_lines",
        "pascal": "SplitOrderIntoLines"
      },
      "shape": "EXPAND",
      "input_content": [
        "orders"
      ],
      "output_content": [
        "order_lines"
      ],
      "body_lines": [
        "order.lines.map(line => ({ parent_order: order.id, product_name: line.product_name, quantity: line.quantity, unit_price: line.unit_price }))"
      ],
      "required_scope": "write orders",
      "required_role": null,
      "input_params": [],
      "output_params": []
    },
    {
      "name": {
        "display": "match orders to lines",
        "snake": "match_orders_to_lines",
        "pascal": "MatchOrdersToLines"
      },
      "shape": "CORRELATE",
      "input_content": [
        "orders",
        "order_lines"
      ],
      "output_content": [
        "reports"
      ],
      "body_lines": [
        "orders.join(order_lines, (o, l) => o.id == l.parent_order)"
      ],
      "required_scope": "read orders",
      "required_role": null,
      "input_params": [],
      "output_params": []
    },
    {
      "name": {
        "display": "triage order",
        "snake": "triage_order",
        "pascal": "TriageOrder"
      },
      "shape": "ROUTE",
      "input_content": [
        "orders"
      ],
      "output_content": [
        "orders",
        "reports"
      ],
      "body_lines": [
        "order.priority == \"high\" ? \"orders\" : \"reports\""
      ],
      "required_scope": "write orders",
      "required_role": null,
      "input_params": [],
      "output_params": []
    }
