// Lark EBNF Grammar for the Termin DSL v2
//
// This is the AUTHORITATIVE specification of the Termin DSL syntax.
// The hand-rolled lexer.py and parser.py must conform to this grammar.
//
// The Termin DSL is line-oriented.  Pre-processing strips comments, section
// dividers, and blank lines.  Each logical line is then fed to this grammar.
//
// Because Termin is NOT free-form (indentation and line breaks carry meaning),
// the grammar operates on pre-tokenised "logical lines" separated by NEWLINE.
// A lightweight preprocessor in lark_parser.py normalises the source before
// Lark sees it.

start: (_toplevel NEWLINE)* _toplevel?

_toplevel: application
         | description
         | identity
         | scopes
         | role_alias
         | role_decl
         | content_decl
         | field_decl
         | access_rule
         | state_decl
         | state_starts
         | state_also
         | state_transition
         | event_when_jexl
         | event_when_v1
         | event_action
         | event_log_level
         | error_handler
         | error_catch_all
         | error_retry
         | error_then
         | story_header
         | story_so_that
         | show_page
         | display_table
         | show_related
         | highlight_rows
         | allow_filtering
         | allow_searching
         | subscribes_to
         | accept_input
         | validate_unique
         | create_as
         | after_saving
         | show_chart
         | display_text
         | display_aggregation
         | nav_bar
         | nav_item
         | api_section
         | api_endpoint
         | stream_decl
         | compute_decl
         | compute_shape
         | compute_body_jexl
         | compute_body_text
         | channel_decl
         | channel_carries
         | channel_direction
         | channel_delivery
         | channel_requires
         | channel_endpoint
         | boundary_decl
         | boundary_contains
         | boundary_identity
         | boundary_exposes


// -------------------------------------------------------------------
// APPLICATION
// -------------------------------------------------------------------
application: "Application:" REST_OF_LINE
description: "Description:" REST_OF_LINE

// -------------------------------------------------------------------
// IDENTITY
// -------------------------------------------------------------------
identity: "Users authenticate with" REST_OF_LINE
scopes: "Scopes are" REST_OF_LINE

// -------------------------------------------------------------------
// ROLES
// -------------------------------------------------------------------
// A "role" has "scope1" and "scope2"   OR   Anonymous has "scope1"
role_decl: ARTICLE QUOTED "has" REST_OF_LINE       -> role_standard
         | BARE_WORD "has" REST_OF_LINE             -> role_bare

// "clerk" is alias for "warehouse clerk"
role_alias: QUOTED "is alias for" QUOTED

// -------------------------------------------------------------------
// CONTENT
// -------------------------------------------------------------------
content_decl: "Content called" QUOTED ":"
field_decl: "Each" REST_OF_LINE
access_rule: "Anyone with" QUOTED "can" REST_OF_LINE

// -------------------------------------------------------------------
// STATE
// -------------------------------------------------------------------
// State for products called "lifecycle":
// State for channel "order webhook" called "lifecycle":
state_decl: "State for" REST_OF_LINE "called" QUOTED ":"
state_starts: ARTICLE REST_OF_LINE "starts as" QUOTED
state_also: ARTICLE REST_OF_LINE "can also be" REST_OF_LINE
state_transition: ARTICLE REST_OF_LINE "can become" REST_OF_LINE

// -------------------------------------------------------------------
// EVENTS
// -------------------------------------------------------------------
event_when_jexl: "When" JEXL_EXPR ":"
event_when_v1: "When" ARTICLE REST_OF_LINE
event_action: "Create" ARTICLE REST_OF_LINE
event_log_level: "Log level:" REST_OF_LINE

// -------------------------------------------------------------------
// ERROR HANDLING
// -------------------------------------------------------------------
// On error from "primitive" where [condition]:
// On error from "primitive":
error_handler: "On error from" QUOTED ("where" JEXL_EXPR)? ":"
// On any error:
error_catch_all: "On any error:"
// Retry N times [with backoff[, maximum delay X]]
error_retry: "Retry" REST_OF_LINE
// Then disable/escalate/notify/create/set
error_then: "Then" REST_OF_LINE

// -------------------------------------------------------------------
// USER STORIES
// -------------------------------------------------------------------
// Supports both "As a role" and "As anonymous"
story_header: "As" REST_OF_LINE
story_so_that: "so that" REST_OF_LINE

// -------------------------------------------------------------------
// DIRECTIVES (inside user stories)
// -------------------------------------------------------------------
show_page: "Show a page called" QUOTED
display_table: "Display a table of" REST_OF_LINE
show_related: "For each" REST_OF_LINE
highlight_rows: "Highlight rows where" REST_OF_LINE
allow_filtering: "Allow filtering by" REST_OF_LINE
allow_searching: "Allow searching by" REST_OF_LINE
subscribes_to: "This table subscribes to" REST_OF_LINE
accept_input: "Accept input for" REST_OF_LINE
validate_unique: "Validate that" REST_OF_LINE
create_as: "Create the" REST_OF_LINE
after_saving: "After saving," REST_OF_LINE
show_chart: "Show a chart of" REST_OF_LINE
display_text: "Display text" REST_OF_LINE
display_aggregation: "Display" REST_OF_LINE

// -------------------------------------------------------------------
// NAVIGATION
// -------------------------------------------------------------------
nav_bar: "Navigation bar:"
nav_item: QUOTED "links to" QUOTED REST_OF_LINE?

// -------------------------------------------------------------------
// API
// -------------------------------------------------------------------
api_section: "Expose a REST API at" REST_OF_LINE ":"?
api_endpoint: HTTP_METHOD API_PATH REST_OF_LINE

// -------------------------------------------------------------------
// STREAMS
// -------------------------------------------------------------------
stream_decl: "Stream" REST_OF_LINE

// -------------------------------------------------------------------
// COMPUTE
// -------------------------------------------------------------------
compute_decl: "Compute called" QUOTED ":"
compute_shape: SHAPE_KW ":" REST_OF_LINE
compute_body_jexl: JEXL_EXPR
compute_body_text: BODY_LINE

// -------------------------------------------------------------------
// CHANNELS (v2: intent-based vocabulary)
// -------------------------------------------------------------------
channel_decl: "Channel called" QUOTED ":"
channel_carries: "Carries" REST_OF_LINE
channel_direction: "Direction:" REST_OF_LINE
channel_delivery: "Delivery:" REST_OF_LINE
channel_requires: "Requires" QUOTED "to" REST_OF_LINE
channel_endpoint: "Endpoint:" REST_OF_LINE

// -------------------------------------------------------------------
// BOUNDARIES
// -------------------------------------------------------------------
boundary_decl: "Boundary called" QUOTED ":"
boundary_contains: "Contains" REST_OF_LINE
boundary_identity: "Identity" REST_OF_LINE
boundary_exposes: "Exposes property" QUOTED ":" REST_OF_LINE


// ===================================================================
// TERMINALS
// ===================================================================

// A quoted string: "anything"
QUOTED: "\"" /[^"]*/ "\""

// [jexl expression] — preserved as-is
JEXL_EXPR: "[" /[^\]]+/ "]"

// Article: A, An, a, an, The, the
ARTICLE: /(?:A|An|The|a|an|the)\b/

// A single word (used where we need exactly one)
WORD: /\w+/

// Bare word for role names like Anonymous
BARE_WORD: /[A-Z]\w*/

// Compute shape keywords (Chain removed in R1)
SHAPE_KW: "Transform" | "Reduce" | "Expand" | "Correlate" | "Route"

// HTTP methods
HTTP_METHOD: "GET" | "POST" | "PUT" | "DELETE" | "PATCH"

// API path: starts with /
API_PATH: /\/\S+/

// A compute body line (non-empty, not starting with [ or a known keyword)
BODY_LINE: /(?![\[\]]).+/

// Everything else on the line after the keyword prefix
REST_OF_LINE: /[^\n]+/

// Line separator (injected by preprocessor)
NEWLINE: /\n/

// Whitespace between tokens on the same line
%import common.WS_INLINE
%ignore WS_INLINE
